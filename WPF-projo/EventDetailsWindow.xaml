<Window x:Class="WPF_projo.EventDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Szczegóły Wydarzenia" Height="450" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Background="#F5F6FA">
        <StackPanel  Margin="20">
            <TextBlock Text="Karta wydarzenia" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Text="Tytuł:" Foreground="#34495E" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="TitleBox" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Height="30" Padding="5" Margin="0,0,0,15"/>

            <TextBlock Text="Data:" Foreground="#34495E" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="DateBox" Text="{Binding Date, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Height="30" Padding="5" Margin="0,0,0,15"/>

            <TextBlock Text="Opis:" Foreground="#34495E" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="DescBox" Text="{Binding ShortDescription, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Height="100" Padding="5" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,25"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="EditBtn" Grid.Column="0" Content="Edytuj" Height="40" Margin="0,0,5,0" Background="#F39C12" Foreground="White" 
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="EditButton_Click"/>

                <Button Grid.Column="1" Content="Zamknij" Height="40" Margin="5,0,0,0" Background="#95A5A6" Foreground="White" 
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="CloseButton_Click"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>