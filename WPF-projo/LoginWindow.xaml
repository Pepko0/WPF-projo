<Window x:Class="WPF_projo.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logowanie do systemu" Height="350" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Background="#F5F6FA">
        <StackPanel VerticalAlignment="Center" Margin="30">
            <TextBlock Text="Zaloguj się" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Nazwa użytkownika:" Foreground="#34495E" Margin="0,0,0,5"/>
            <TextBox x:Name="UsernameTextBox" Height="30" Padding="5" Margin="0,0,0,15"/>

            <TextBlock Text="Hasło:" Foreground="#34495E" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" Height="30" Padding="5" Margin="0,0,0,25"/>

            <Button Content="Zaloguj" Height="40" Background="#27AE60" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="LoginSubmit_Click"/>
        </StackPanel>
    </Grid>
</Window>