<Window x:Class="WPF_projo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF-projo - System Zarządzania Domem Kultury" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#2C3E50">
            <TextBlock Text="WPF-projo" Foreground="White" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0,0,0"/>
            <Button Content="Zaloguj się" HorizontalAlignment="Right" Width="120" Height="35" Margin="0,0,20,0" 
                    Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                    Click="OpenLoginWindow_Click"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" Margin="20">
                <StackPanel>
                    <TextBlock Text="Wydarzenia" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#2F3640"/>

                    <ItemsControl ItemsSource="{Binding Events}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,15" Padding="15">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                                    </Border.Effect>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="#2980B9"/>
                                            <TextBlock Text="{Binding Date}" FontSize="14" Foreground="#7F8C8D" Margin="0,5,0,5"/>
                                            <TextBlock Text="{Binding ShortDescription}" TextWrapping="Wrap" Foreground="#34495E"/>
                                        </StackPanel>

                                        <Button Grid.Column="1" Content="Szczegóły" Width="80" Height="35" Background="#3498DB" Foreground="White" 
                                                FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" Margin="0,0,10,0"
                                                Command="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                CommandParameter="{Binding}"/>

                                        <Button Grid.Column="2" Content="Usuń" Width="80" Height="35" Background="#E74C3C" Foreground="White" 
                                                FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"
                                                Command="{Binding DataContext.DeleteEventCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                CommandParameter="{Binding}"/>              
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Background="White" Padding="20" Margin="0,20,20,20" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Dodaj wydarzenie" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

                    <TextBlock Text="Tytuł:" Foreground="#34495E" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewEventTitle, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="5" Margin="0,0,0,15"/>

                    <TextBlock Text="Data:" Foreground="#34495E" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewEventDate, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="5" Margin="0,0,0,15"/>

                    <TextBlock Text="Krótki opis:" Foreground="#34495E" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewEventDescription, UpdateSourceTrigger=PropertyChanged}" Height="80" Padding="5" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,20"/>

                    <Button Content="Dodaj" Height="40" Background="#27AE60" Foreground="White" FontWeight="Bold" 
                            BorderThickness="0" Cursor="Hand" Command="{Binding AddEventCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>